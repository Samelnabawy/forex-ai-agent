# ============================================================
# FOREX AI TRADING AGENT — Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# --- Application ---
APP_ENV=development            # development | staging | production
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                # json | console

# --- PostgreSQL (pgvector + TimescaleDB) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=forex_agent
POSTGRES_USER=forex
POSTGRES_PASSWORD=changeme_in_production
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_REASONING_MODEL=claude-sonnet-4-20250514
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001

# --- Data Providers ---
# Polygon.io (price data — free tier available)
POLYGON_API_KEY=
# Twelve Data (alternative price feed)
TWELVE_DATA_API_KEY=
# Finnhub (news + sentiment)
FINNHUB_API_KEY=
# NewsAPI (headlines)
NEWSAPI_KEY=
# FRED (economic data)
FRED_API_KEY=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Trading ---
INITIAL_CAPITAL=10000.00
PAPER_TRADING=true              # true = no real money, false = live

# --- Monitoring ---
GRAFANA_ADMIN_PASSWORD=changeme
PROMETHEUS_PORT=9090
